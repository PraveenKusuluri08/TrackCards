// PayTrack AI - Credit Card Management
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth / Auth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   // For credentials auth
  timezone      String?   @default("America/New_York") @db.VarChar(64)
  reminderDays  String?   @default("7,3,1") @map("reminder_days") @db.VarChar(32)
  reminderTime  String?   @default("09:00") @map("reminder_time") @db.VarChar(8)
  createdAt     DateTime  @default(now()) @map("created_at")

  accounts            Account[]
  sessions            Session[]
  creditCards         CreditCard[]
  notifications       Notification[]
  emailVerifications  EmailVerification[]
  balanceSnapshots    BalanceSnapshot[]
  inAppNotifications  InAppNotification[]

  @@map("users")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("email_verifications")
}

model CreditCard {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  cardName        String    @map("card_name")
  issuerName      String    @map("issuer_name")
  lastFourDigits  String?   @map("last_four_digits")
  creditLimit     Decimal   @map("credit_limit") @db.Decimal(12, 2)
  currentBalance  Decimal   @map("current_balance") @db.Decimal(12, 2)
  minimumDue      Decimal   @map("minimum_due") @db.Decimal(12, 2)
  fullDue         Decimal   @map("full_due") @db.Decimal(12, 2)
  dueDate         DateTime  @map("due_date") @db.Date
  statementDate   DateTime  @map("statement_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentHistory  PaymentHistory[]
  pendingPayments PendingPayment[]
  notifications   Notification[]
  inAppNotifications InAppNotification[]

  @@map("credit_cards")
}

model PaymentHistory {
  id          String   @id @default(cuid())
  cardId      String   @map("card_id")
  amountPaid  Decimal  @map("amount_paid") @db.Decimal(12, 2)
  paidDate    DateTime @map("paid_date") @db.Date
  paymentType String   @map("payment_type") // "minimum", "full", "partial"
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("payment_history")
}

model PendingPayment {
  id             String   @id @default(cuid())
  cardId         String   @map("card_id")
  amountPaid     Decimal  @map("amount_paid") @db.Decimal(12, 2)
  paidDate       DateTime @map("paid_date") @db.Date
  description    String?  @db.Text
  daysToPost     Int      @map("days_to_post")
  balanceUpdated Boolean  @default(false) @map("balance_updated")
  createdAt      DateTime @default(now()) @map("created_at")

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("pending_payments")
}

model Notification {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  cardId       String?  @map("card_id")
  dueDate      DateTime @map("due_date") @db.Date
  reminderDays Int      @map("reminder_days")
  sentStatus   Boolean  @default(false) @map("sent_status")
  sentAt       DateTime? @map("sent_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  card CreditCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@unique([cardId, dueDate, reminderDays])
  @@map("notifications")
}

model BalanceSnapshot {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  snapshotDate  DateTime @map("snapshot_date") @db.Date
  totalBalance  Decimal  @map("total_balance") @db.Decimal(12, 2)
  cardBalances  Json     @map("card_balances")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate])
  @@map("balance_snapshots")
}

model InAppNotification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  cardId    String?  @map("card_id")
  type      String   @db.VarChar(32)
  title     String   @db.VarChar(140)
  body      String?  @db.Text
  eventDate DateTime @map("event_date") @db.Date
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  card CreditCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@unique([userId, type, cardId, eventDate])
  @@index([userId, readAt, createdAt])
  @@map("in_app_notifications")
}
